<Window x:Class="Seans_Account_Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sean's Account Manager" Height="660" Width="900" ResizeMode="NoResize"
        Background="{StaticResource BgDark}" WindowStartupLocation="CenterScreen">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="0"
                      GlassFrameThickness="0" CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TITLE BAR -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="{StaticResource BgSidebar}"
                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Sean's Account Manager"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="11" VerticalAlignment="Center" Margin="14,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="-" Style="{StaticResource WinBtn}" Click="MinimizeBtn_Click"
                            WindowChrome.IsHitTestVisibleInChrome="True" FontSize="16" Padding="0,0,0,4"/>
                    <Button Content="X" Style="{StaticResource WinCloseBtn}" Click="CloseBtn_Click"
                            WindowChrome.IsHitTestVisibleInChrome="True"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- SIDEBAR -->
        <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource BgSidebar}"
                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Top" Margin="12,14,12,0">
                    <TextBlock Text="Sean's Account Manager"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </StackPanel>
                <Rectangle DockPanel.Dock="Top" Height="1" Fill="{StaticResource BorderSubtle}" Margin="0,10,0,4"/>

                <StackPanel DockPanel.Dock="Top">
                    <RadioButton x:Name="NavAccounts"    Content="Accounts"     Style="{StaticResource NavButton}" IsChecked="True" GroupName="Nav" Checked="Nav_Checked" Tag="Accounts"/>
                    <RadioButton x:Name="NavMultiRoblox" Content="Multi Roblox" Style="{StaticResource NavButton}" GroupName="Nav" Checked="Nav_Checked" Tag="MultiRoblox"/>
                    <RadioButton x:Name="NavAntiAfk"     Content="Anti AFK"     Style="{StaticResource NavButton}" GroupName="Nav" Checked="Nav_Checked" Tag="AntiAfk"/>
                    <RadioButton x:Name="NavSettings"    Content="Settings"     Style="{StaticResource NavButton}" GroupName="Nav" Checked="Nav_Checked" Tag="Settings"/>
                    <RadioButton x:Name="NavConsole"     Content="Console"      Style="{StaticResource NavButton}" GroupName="Nav" Checked="Nav_Checked" Tag="Console"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom" Text="v1.0"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="10" Margin="12,0,0,12"/>
            </DockPanel>
        </Border>

        <!-- TAB CONTENT -->
        <Grid Grid.Row="1" Grid.Column="1">

            <!-- ===== ACCOUNTS TAB ===== -->
            <Grid x:Name="AccountsTab" Visibility="Visible" Opacity="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <!-- Account list -->
                <Grid Grid.Column="0" Margin="14,12,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Accounts"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock x:Name="AccountCountLabel" Text="0 accounts"
                                       Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Refresh" Style="{StaticResource GhostButton}"
                                Click="RefreshAll_Click" VerticalAlignment="Center"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="AccountsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BgCard}" Margin="0,0,0,3" Padding="9,7"
                                            BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                            Tag="{Binding UserId}"
                                            AllowDrop="True"
                                            PreviewMouseLeftButtonDown="AccountCard_MouseDown"
                                            PreviewMouseMove="AccountCard_MouseMove"
                                            Drop="AccountCard_Drop"
                                            DragEnter="AccountCard_DragEnter"
                                            DragLeave="AccountCard_DragLeave">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="&#x22EE;&#x22EE;"
                                                       Foreground="{StaticResource TextMuted}"
                                                       FontSize="11" VerticalAlignment="Center"
                                                       Margin="0,0,7,0" Cursor="SizeAll" ToolTip="Drag to reorder"/>

                                            <CheckBox Grid.Column="1" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      VerticalAlignment="Center" Margin="0,0,9,0"/>

                                            <Border Grid.Column="2" Width="34" Height="34"
                                                    ClipToBounds="True" Margin="0,0,9,0"
                                                    BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1">
                                                <Grid>
                                                    <Image Source="{Binding AvatarUrl}" Stretch="UniformToFill"/>
                                                    <Rectangle Width="9" Height="9"
                                                               Fill="{StaticResource DangerBrush}"
                                                               Stroke="{StaticResource BgCard}" StrokeThickness="1.5"
                                                               HorizontalAlignment="Right" VerticalAlignment="Top"
                                                               Visibility="{Binding IsCookieValid, Converter={StaticResource BoolToInvisibleConverter}}"/>
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Username}"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontWeight="SemiBold" FontSize="13"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding Robux, StringFormat='{}{0} R$'}"
                                                               Foreground="{StaticResource SuccessBrush}"
                                                               FontSize="11" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding PresenceStatus}"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               FontSize="11" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding Note}"
                                                               Foreground="{StaticResource WarningBrush}"
                                                               FontSize="11" FontStyle="Italic"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding RejoinStatusText}"
                                                           Foreground="{StaticResource TextMuted}"
                                                           FontSize="10" Margin="0,1,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="{Binding RejoinButtonText}"
                                                        Padding="7,4" FontSize="11" Cursor="Hand"
                                                        BorderThickness="0"
                                                        Foreground="{StaticResource TextPrimary}"
                                                        Background="{Binding RejoinButtonColor}"
                                                        Tag="{Binding UserId}" Click="ToggleRejoin_Click" Margin="0,0,3,0"/>
                                                <Button Content="Note" Style="{StaticResource GhostButton}"
                                                        Padding="7,4" FontSize="11"
                                                        Tag="{Binding UserId}" Click="EditNote_Click" Margin="0,0,3,0"/>
                                                <Button Content="Join" Style="{StaticResource PrimaryButton}"
                                                        Padding="10,4" FontSize="11"
                                                        Tag="{Binding UserId}" Click="JoinAccount_Click" Margin="0,0,3,0"/>
                                                <Button Content="&#x2715;" Style="{StaticResource DangerButton}"
                                                        Padding="7,4" FontSize="11"
                                                        Tag="{Binding UserId}" Click="DeleteAccount_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button Grid.Row="2" Content="+ Add Account" Style="{StaticResource PrimaryButton}"
                            Click="AddAccount_Click" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                </Grid>

                <!-- Right panel -->
                <Border Grid.Column="1" Background="{StaticResource BgPanel}"
                        BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1,0,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12,12,12,12">
                            <TextBlock Text="Launch" Foreground="{StaticResource TextPrimary}"
                                       FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>

                            <TextBlock Text="Place ID" Foreground="{StaticResource TextSecondary}"
                                       FontSize="11" Margin="0,0,0,3"/>
                            <TextBox x:Name="PlaceIdBox" Margin="0,0,0,3" TextChanged="PlaceIdBox_TextChanged"/>
                            <TextBlock x:Name="GameNameLabel" Text=""
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="11" FontStyle="Italic" Margin="0,0,0,10"
                                       TextTrimming="CharacterEllipsis"/>

                            <TextBlock Text="Job ID (optional)" Foreground="{StaticResource TextSecondary}"
                                       FontSize="11" Margin="0,0,0,3"/>
                            <TextBox x:Name="JobIdBox" Margin="0,0,0,10"/>

                            <Button Content="Join / Launch Selected" Style="{StaticResource PrimaryButton}"
                                    Click="JoinPlace_Click" HorizontalAlignment="Stretch"/>

                            <Rectangle Height="1" Fill="{StaticResource BorderSubtle}" Margin="0,12,0,10"/>

                            <TextBlock Text="Recent Games" Foreground="{StaticResource TextSecondary}"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>

                            <ItemsControl x:Name="RecentGamesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource BgCard}" Margin="0,0,0,3" Padding="7"
                                                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                                Cursor="Hand" MouseLeftButtonUp="RecentGame_Click"
                                                Tag="{Binding PlaceId}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="30" Height="30"
                                                        ClipToBounds="True" Margin="0,0,8,0"
                                                        BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1">
                                                    <Image Source="{Binding IconUrl}" Stretch="UniformToFill"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding PlaceId}"
                                                               Foreground="{StaticResource TextMuted}" FontSize="10"/>
                                                </StackPanel>
                                                <Button Grid.Column="2" Content="âœ•"
                                                        Background="Transparent"
                                                        Foreground="{StaticResource TextMuted}"
                                                        BorderThickness="0" Padding="4,2" FontSize="10"
                                                        Cursor="Hand" Tag="{Binding PlaceId}"
                                                        Click="RemoveRecentGame_Click"
                                                        VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock x:Name="NoRecentLabel" Text="No recent games."
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ===== MULTI ROBLOX TAB ===== -->
            <Grid x:Name="MultiRobloxTab" Visibility="Collapsed" Margin="18,14,18,14">
                <StackPanel>
                    <TextBlock Text="Multi Roblox" Foreground="{StaticResource TextPrimary}"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <Border Background="{StaticResource BgCard}"
                            BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                            Padding="12,10" Margin="0,0,0,6">
                        <StackPanel>
                            <CheckBox x:Name="EnableMultiRobloxCheckBox"
                                      Content="Enabled Multi Roblox"
                                      Foreground="{StaticResource TextPrimary}"
                                      FontSize="12"
                                      Checked="EnableMultiRobloxCheckBox_Checked"
                                      Unchecked="EnableMultiRobloxCheckBox_Unchecked"/>

                            <TextBlock Text="Handle64 is required to clear the Roblox singleton handle."
                                       Foreground="{StaticResource TextSecondary}" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,6,0,0"/>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button x:Name="DownloadHandle64Button"
                                        Content="Download Handle64"
                                        Style="{StaticResource GhostButton}"
                                        Click="DownloadHandle64_Click"/>
                                <TextBlock x:Name="Handle64StatusLabel"
                                           Text="[Handle64 not found]"
                                           Foreground="{StaticResource TextMuted}"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource BgCard}"
                            BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                            Padding="12,10" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Open windows"
                                           Foreground="{StaticResource TextPrimary}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock x:Name="OpenWindowsLabel" Text="Loadingâ€¦"
                                           Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Refresh"
                                    Style="{StaticResource GhostButton}"
                                    Click="RefreshOpenWindows_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Background="{StaticResource BgCard}"
                            BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                            Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="Close all Roblox"
                                       Foreground="{StaticResource TextPrimary}" FontSize="12" FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <Button Content="Close All Roblox" Style="{StaticResource DangerButton}"
                                    Click="CloseAllRoblox_Click" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ===== ANTI AFK TAB ===== -->
            <Grid x:Name="AntiAfkTab" Visibility="Collapsed" Margin="18,14,18,14">
                <StackPanel>
                    <TextBlock Text="Anti AFK" Foreground="{StaticResource TextPrimary}"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <Border Background="{StaticResource BgCard}"
                            BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                            Padding="12,10" Margin="0,0,0,6">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Interval (min)" Foreground="{StaticResource TextSecondary}"
                                               FontSize="11" Margin="0,0,0,3"/>
                                    <TextBox x:Name="AfkIntervalBox" Text="10"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Key" Foreground="{StaticResource TextSecondary}"
                                               FontSize="11" Margin="0,0,0,3"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox x:Name="AfkKeyBindBox" Text="W" IsReadOnly="True" Width="130"/>
                                        <Button Content="Bind" Style="{StaticResource GhostButton}"
                                                Click="BeginBindAfkKey_Click" Margin="6,0,0,0" Padding="10,5"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Press count" Foreground="{StaticResource TextSecondary}"
                                               FontSize="11" Margin="0,0,0,3"/>
                                    <TextBox x:Name="AfkPressCountBox" Text="1"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="AntiAfkToggleBtn" Content="Start Anti-AFK"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="ToggleAntiAfk_Click" Padding="14,7"/>
                                <Button Content="Test Now" Style="{StaticResource GhostButton}"
                                        Click="TestAntiAfk_Click" Margin="6,0,0,0" Padding="14,7"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource BgCard}"
                            BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                            Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="Status" Foreground="{StaticResource TextPrimary}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBlock x:Name="AfkStatusLabel"
                                       Text="Not running."
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="12" TextWrapping="Wrap"/>
                            <TextBlock Text="10-minute intervals recommended â€” shorter may get flagged."
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11" TextWrapping="Wrap" Margin="0,7,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ===== SETTINGS TAB ===== -->
            <Grid x:Name="SettingsTab" Visibility="Collapsed" Margin="18,14,18,14">
                <StackPanel>
                    <TextBlock Text="Settings" Foreground="{StaticResource TextPrimary}"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <Border Background="{StaticResource BgCard}"
                            BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                            Padding="12,10" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="General" Foreground="{StaticResource TextPrimary}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>

                            <CheckBox x:Name="AlwaysOnTopCheckBox"
                                      Content="Always On Top"
                                      Foreground="{StaticResource TextSecondary}"
                                      Margin="0,0,0,6"
                                      Checked="GeneralSettingCheckBox_Changed"
                                      Unchecked="GeneralSettingCheckBox_Changed"/>

                            <CheckBox x:Name="ConfirmBeforeLaunchCheckBox"
                                      Content="Confirm Before Launch"
                                      Foreground="{StaticResource TextSecondary}"
                                      Checked="GeneralSettingCheckBox_Changed"
                                      Unchecked="GeneralSettingCheckBox_Changed"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource BgCard}"
                            BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                            Padding="12,10" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="Encryption" Foreground="{StaticResource TextPrimary}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="Account cookies are encrypted with Windows DPAPI, tied to your Windows user. No passwords needed."
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource BgCard}"
                            BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                            Padding="12,10" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="Data Location" Foreground="{StaticResource TextPrimary}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="%AppData%\SeansAccountManager   "
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="12" FontFamily="Consolas" Margin="0,0,0,8"/>
                            <Button Content="Open Data Folder" Style="{StaticResource GhostButton}"
                                    Click="OpenDataFolder_Click" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource BgCard}"
                            BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                            Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="About" Foreground="{StaticResource TextPrimary}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" TextWrapping="Wrap">
                                Sean's Account Manager · v1.0<LineBreak/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ===== CONSOLE TAB ===== -->
            <Grid x:Name="ConsoleTab" Visibility="Collapsed" Margin="18,14,18,14">
                <StackPanel>
                    <TextBlock Text="Console" Foreground="{StaticResource TextPrimary}"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <Border Background="{StaticResource BgCard}"
                            BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                            Padding="12,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="Clear" Style="{StaticResource GhostButton}"
                                        Click="ClearConsole_Click" Padding="12,6"/>
                                <Button Content="Copy" Style="{StaticResource GhostButton}"
                                        Click="CopyConsole_Click" Margin="6,0,0,0" Padding="12,6"/>
                                <ComboBox x:Name="ConsoleFilterBox" Margin="12,0,0,0" Width="150"
                                          SelectionChanged="ConsoleFilterBox_SelectionChanged"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="All" Tag="All"/>
                                    <ComboBoxItem Content="Anti-AFK" Tag="AntiAfk"/>
                                    <ComboBoxItem Content="Multi Roblox" Tag="MultiRoblox"/>
                                    <ComboBoxItem Content="Errors" Tag="Errors"/>
                                    <ComboBoxItem Content="App" Tag="App"/>
                                    <ComboBoxItem Content="Trace" Tag="Trace"/>
                                </ComboBox>
                            </StackPanel>

                            <TextBox Grid.Row="1" x:Name="ConsoleOutputBox"
                                     IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="360"
                                     FontFamily="Consolas"
                                     FontSize="11"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

        </Grid>
    </Grid>
</Window>