<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>Seans_Account_Manager</RootNamespace>
    <AssemblyName>Seans_Account_Manager</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationManifest>app.manifest</ApplicationManifest>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.4078.44" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\*.png" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="NativeDlls\WebView2Loader.dll">
      <LogicalName>Seans_Account_Manager.NativeDlls.WebView2Loader.dll</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

</Project>