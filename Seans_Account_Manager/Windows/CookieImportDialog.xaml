<Window x:Class="Seans_Account_Manager.Windows.CookieImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Cookie" Height="260" Width="460"
        Background="#18191C" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text=".ROBLOSECURITY Cookie" Foreground="#E0E2E6"
                   FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1"
                   Foreground="#888C96" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"><Run Text="Paste the full cookie value below."/><LineBreak/><Run/></TextBlock>

        <TextBox x:Name="CookieBox" Grid.Row="2"
                 Background="#22242A" Foreground="#E0E2E6"
                 BorderBrush="#303238" BorderThickness="1"
                 Padding="8" CaretBrush="White"
                 TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"/>

        <TextBlock x:Name="ErrorLabel" Grid.Row="3" Text=""
                   Foreground="#E8CCCC" FontSize="11" Margin="0,8,0,0"
                   TextWrapping="Wrap" Visibility="Collapsed"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Background="#24262C" Foreground="#E0E2E6" BorderThickness="0"
                    Padding="14,7" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button x:Name="ImportButton" Content="Import" Background="#3C4050" Foreground="White" BorderThickness="0"
                    Padding="14,7" Click="Import_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>