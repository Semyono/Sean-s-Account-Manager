<Window x:Class="FemBoy_Account_Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FemBoy Account Manager" Height="640" Width="900"
        Background="{StaticResource BgDark}" WindowStartupLocation="CenterScreen">

    <DockPanel>
        <!-- Thin gradient stripe at the top (flag accent) -->
        <Rectangle DockPanel.Dock="Top" Height="2" Fill="{StaticResource FlagStripe}"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- ============ SIDEBAR ============ -->
            <Border Grid.Column="0" Background="{StaticResource BgSidebar}">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Top" Margin="16,20,16,20">
                        <TextBlock Text="FemBoy" Foreground="{StaticResource AccentPink}" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Account Manager" Foreground="{StaticResource AccentBlue}" FontSize="12" Margin="0,-2,0,0"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Top" Margin="10,0">
                        <RadioButton Content="Accounts" Style="{StaticResource NavButton}" IsChecked="True" GroupName="Nav"/>
                        <RadioButton Content="Multi Roblox" Style="{StaticResource NavButton}" GroupName="Nav" IsEnabled="False"/>
                        <RadioButton Content="Anti AFK" Style="{StaticResource NavButton}" GroupName="Nav" IsEnabled="False"/>
                        <RadioButton Content="Settings" Style="{StaticResource NavButton}" GroupName="Nav" IsEnabled="False"/>
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Bottom" Text="v1.0 @BeAFemboy" Foreground="{StaticResource TextMuted}"
                               FontSize="10" Margin="18,0,0,14"/>
                </DockPanel>
            </Border>

            <!-- ============ ACCOUNT LIST ============ -->
            <Grid Grid.Column="1" Margin="20,20,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Account List" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold"/>
                        <TextBlock x:Name="AccountCountLabel" Text="0 accounts" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Refresh List" Style="{StaticResource GhostButton}" Click="RefreshAll_Click"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="AccountsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgCard}" Margin="0,0,0,8" Padding="12"
                                        BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                        Tag="{Binding UserId}"
                                        AllowDrop="True"
                                        PreviewMouseLeftButtonDown="AccountCard_MouseDown"
                                        PreviewMouseMove="AccountCard_MouseMove"
                                        Drop="AccountCard_Drop"
                                        DragEnter="AccountCard_DragEnter"
                                        DragLeave="AccountCard_DragLeave">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="⋮⋮" Foreground="{StaticResource TextMuted}"
                                             FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"
                                             Cursor="SizeAll" ToolTip="Drag to reorder"/>

                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  VerticalAlignment="Center" Margin="0,0,12,0"/>

                                        <Grid Grid.Column="1" Margin="0,0,12,0">
                                            <Border Width="42" Height="42" ClipToBounds="True"
                                                    BorderBrush="{StaticResource AccentPink}" BorderThickness="1.5">
                                                <Image Source="{Binding AvatarUrl}" Stretch="UniformToFill"/>
                                            </Border>
                                            <Rectangle Width="11" Height="11" Fill="{StaticResource DangerBrush}"
                                                       Stroke="{StaticResource BgCard}" StrokeThickness="2"
                                                       HorizontalAlignment="Right" VerticalAlignment="Top"
                                                       Visibility="{Binding IsCookieValid, Converter={StaticResource BoolToInvisibleConverter}}"/>
                                        </Grid>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Username}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="14"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding Robux, StringFormat='{}{0} R$'}" Foreground="{StaticResource SuccessBrush}" FontSize="11" Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding PresenceStatus}" Foreground="{StaticResource AccentBlue}" FontSize="11" Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding Note}" Foreground="{StaticResource WarningBrush}" FontSize="11" FontStyle="Italic"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding RejoinStatusText}" Foreground="{StaticResource AccentPink}" FontSize="10" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="{Binding RejoinButtonText}" Padding="10,6" FontSize="11" Cursor="Hand"
                                                 BorderThickness="0" Foreground="{StaticResource TextPrimary}"
                                                 Background="{Binding RejoinButtonColor}"
                                                     Tag="{Binding UserId}" Click="ToggleRejoin_Click" Margin="0,0,6,0"/>
                                            <Button Content="Note" Style="{StaticResource GhostButton}" Padding="10,6" FontSize="11"
                                                 Tag="{Binding UserId}" Click="EditNote_Click" Margin="0,0,6,0"/>
                                            <Button Content="Join" Style="{StaticResource PrimaryButton}" Padding="12,6" FontSize="11"
                                                 Tag="{Binding UserId}" Click="JoinAccount_Click" Margin="0,0,6,0"/>
                                            <Button Content="🗑" Style="{StaticResource DangerButton}" Padding="8,6" FontSize="11"
                                                 Tag="{Binding UserId}" Click="DeleteAccount_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,14,0,0">
                    <Button Content="+ Add Account" Style="{StaticResource PrimaryButton}" Click="AddAccount_Click" Margin="0,0,8,0"/>
                    <Button Content="Close All Roblox" Style="{StaticResource DangerButton}" Click="CloseAllRoblox_Click"/>
                </StackPanel>
            </Grid>

            <!-- ============ ACTIONS PANEL ============ -->
            <Border Grid.Column="2" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20,20,20,20">
                        <TextBlock Text="Actions" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

                        <TextBlock Text="Place ID" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,6"/>
                        <TextBox x:Name="PlaceIdBox" Margin="0,0,0,4" TextChanged="PlaceIdBox_TextChanged"/>
                        <TextBlock x:Name="GameNameLabel" Text="" Foreground="{StaticResource AccentPink}"
                                FontSize="11" FontStyle="Italic" Margin="0,0,0,14"
                                TextTrimming="CharacterEllipsis"/>

                        <TextBlock Text="Job ID (optional)" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,6"/>
                        <TextBox x:Name="JobIdBox" Margin="0,0,0,14"/>

                        <Button Content="Join / Launch Selected" Style="{StaticResource PrimaryButton}" Click="JoinPlace_Click" Margin="0,0,0,10"/>

                        <Rectangle Height="1" Fill="{StaticResource BorderSubtle}" Margin="0,10,0,14"/>

                        <TextBlock Text="Recent Games" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <Rectangle Height="1" Fill="{StaticResource BorderSubtle}" Margin="0,14,0,14"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Auto-Rejoin" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Stop All" Style="{StaticResource GhostButton}" Padding="8,4" FontSize="10" Click="StopAllRejoin_Click"/>
                        </Grid>

                        <TextBlock x:Name="RejoinInfoLabel"
                            Text="Click 'Rejoin' on an account to auto-restart it if it crashes."
                            Foreground="{StaticResource TextMuted}" FontSize="11" FontStyle="Italic"
                             TextWrapping="Wrap"/>

                        <ItemsControl x:Name="RecentGamesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BgCard}" Margin="0,0,0,6" Padding="8"
                                            BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="RecentGame_Click"
                                            Tag="{Binding PlaceId}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="36" Height="36" ClipToBounds="True"
                                                    BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                                    Margin="0,0,10,0">
                                                <Image Source="{Binding IconUrl}" Stretch="UniformToFill"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding PlaceId}" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                                            </StackPanel>

                                            <Button Grid.Column="2" Content="✕" Background="Transparent" Foreground="{StaticResource TextMuted}"
                                                    BorderThickness="0" Padding="6,2" FontSize="10" Cursor="Hand"
                                                    Tag="{Binding PlaceId}" Click="RemoveRecentGame_Click"
                                                    VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="NoRecentLabel" Text="No recent games yet. Launch one to see it here."
                                   Foreground="{StaticResource TextMuted}" FontSize="11" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>